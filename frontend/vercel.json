{
  "installCommand": "sh \"$(find . .. ../.. ../../.. -name node_modules -prune -o -name vercel-install.sh -print -quit)\"",
  "buildCommand": "sh \"$(find . .. ../.. ../../.. -name node_modules -prune -o -name vercel-build.sh -print -quit)\"",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
