{
  "installCommand": "sh frontend/vercel-install.sh || sh vercel-install.sh || sh ../frontend/vercel-install.sh",
  "buildCommand": "sh frontend/vercel-build.sh || sh vercel-build.sh || sh ../frontend/vercel-build.sh",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
